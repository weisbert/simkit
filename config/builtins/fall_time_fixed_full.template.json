{
  "_doc": "Fall time at V_LOW%-V_HIGH% of an explicit rail span [VSS, VDD] over the full (unclipped) waveform. Reversed-threshold convention as fall_time_fixed. Same shape but without the t_1..t_2 window.",
  "template_schema_version": 1,
  "name": "fall_time_fixed_full",
  "short_alias": "Ftime",
  "expression": "average(riseTime(vtime('$ANALYSIS \"$SIG\") $VSS nil $VDD nil $V_LOW $V_HIGH t \"time\"))",
  "params": [
    {"key": "SIG",      "kind": "signal"},
    {"key": "ANALYSIS", "kind": "string", "default": "tran"},
    {"key": "VSS",      "kind": "string", "default": "0"},
    {"key": "VDD",      "kind": "string", "default": "VAR(\"VDD\")"},
    {"key": "V_LOW",    "kind": "number", "default": "90"},
    {"key": "V_HIGH",   "kind": "number", "default": "10"}
  ],
  "eval_type": "point",
  "plot": true,
  "save": false,
  "unit": "s"
}
