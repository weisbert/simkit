{
  "_doc": "Fall time at V_LOW%-V_HIGH% of an explicit rail span [VSS, VDD]. Reversed-threshold convention as fall_time_auto.",
  "template_schema_version": 1,
  "name": "fall_time_fixed",
  "short_alias": "Ftime",
  "expression": "average(riseTime(clip(vtime('$ANALYSIS \"$SIG\") $T_START $T_END) $VSS nil $VDD nil $V_LOW $V_HIGH t \"time\"))",
  "params": [
    {"key": "SIG",      "kind": "signal"},
    {"key": "ANALYSIS", "kind": "string", "default": "tran"},
    {"key": "T_START",  "kind": "string", "default": "VAR(\"t_1\")"},
    {"key": "T_END",    "kind": "string", "default": "VAR(\"t_2\")"},
    {"key": "VSS",      "kind": "string", "default": "0"},
    {"key": "VDD",      "kind": "string", "default": "VAR(\"VDD\")"},
    {"key": "V_LOW",    "kind": "number", "default": "90"},
    {"key": "V_HIGH",   "kind": "number", "default": "10"}
  ],
  "eval_type": "point",
  "plot": true,
  "save": false,
  "unit": "s"
}
