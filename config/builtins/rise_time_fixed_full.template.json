{
  "_doc": "Rise time at V_LOW%-V_HIGH% of an explicit rail span [VSS, VDD] over the full (unclipped) waveform. Same shape as rise_time_fixed but without the t_1..t_2 window. This is the canonical shape of the user's live Rtime_clkout output.",
  "template_schema_version": 1,
  "name": "rise_time_fixed_full",
  "short_alias": "Rtime",
  "expression": "average(riseTime(vtime('$ANALYSIS \"$SIG\") $VSS nil $VDD nil $V_LOW $V_HIGH t \"time\"))",
  "params": [
    {"key": "SIG",      "kind": "signal"},
    {"key": "ANALYSIS", "kind": "string", "default": "tran"},
    {"key": "VSS",      "kind": "string", "default": "0",            "doc": "Lower rail (Cadence expression)."},
    {"key": "VDD",      "kind": "string", "default": "VAR(\"VDD\")", "doc": "Upper rail (Cadence expression)."},
    {"key": "V_LOW",    "kind": "number", "default": "10"},
    {"key": "V_HIGH",   "kind": "number", "default": "90"}
  ],
  "eval_type": "point",
  "plot": true,
  "save": false,
  "unit": "s"
}
